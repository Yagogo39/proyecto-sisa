{
  "name": "sis-a",
  "private": true,
  "version": "1.0.0",
  "description": "SIS-A",
  "author": "",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:backend": "cd ../backend && npm run build",
    "dist": "npm run build && npm run build:backend && electron-builder"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.15.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.donmax.sisa",
    "productName": "SIS-A",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-bin/backend.exe",
        "to": "backend.exe"
      },
      {
        "from": "../backend/schema.sql",
        "to": "schema.sql"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SIS-A Papeleria",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}